# Copy to .env and fill in. .env is gitignored — keep camera credentials there.

# HMAC secret for signing session tokens. Generate, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# Live RTSP (main H.264 stream, channel 101) per camera, as JSON.
# These must be reachable from the streamer container over the LAN.
CAMERAS={"cam1":"rtsp://admin:PASSWORD@192.168.0.150:554/Streaming/Channels/101","cam2":"rtsp://admin:PASSWORD@192.168.0.151:554/Streaming/Channels/101"}

# Optional tuning (defaults shown):
# TOKEN_TTL=86400
# BUFFER_HIGH=20
# BUFFER_LOW=10
